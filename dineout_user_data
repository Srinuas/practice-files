#!/bin/bash
sudo yum update -y
sudo yum install httpd -y
sudo systemctl start httpd
sudo systemctl enable httpd
sudo yum install stress -y
sudo hostnamectl set-hostname dineout

sudo bash -c 'cat <<EOF > /var/www/html/index.html
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<title>Dineout — Demo</title>
<meta name="viewport" content="width=device-width, initial-scale=1" />
<style>
  :root { --brand:#ff2e63; --bg:#fff7fa; --text:#222; --muted:#666; --border:#f1d6e0; --card:#fff; }
  *{box-sizing:border-box}
  body{margin:0;font-family:system-ui,Segoe UI,Roboto,sans-serif;background:var(--bg);color:var(--text)}
  header{position:sticky;top:0;background:#fff;border-bottom:1px solid var(--border);z-index:10}
  .nav{max-width:1000px;margin:0 auto;padding:12px 16px;display:flex;gap:12px;align-items:center}
  .logo{font-weight:900;color:var(--brand);font-size:20px}
  .container{max-width:1000px;margin:0 auto;padding:16px;display:grid;gap:14px}
  .bar{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:10px}
  @media (max-width:820px){.bar{grid-template-columns:1fr 1fr}}
  input,select{width:100%;padding:10px 12px;border:1px solid #eee;border-radius:10px}
  .grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}
  @media (max-width:820px){.grid{grid-template-columns:1fr}}
  .card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:12px;display:grid;gap:8px}
  .thumb{height:140px;border-radius:10px;background:linear-gradient(135deg,#ffd0df,#ffc2d7);display:grid;place-items:center;color:#7a1330;font-weight:800}
  .row{display:flex;justify-content:space-between;align-items:center;gap:8px}
  .meta{font-size:13px;color:var(--muted)}
  .slot{all:unset;border:1px solid #eee;padding:8px 10px;border-radius:8px;background:#fff;cursor:pointer}
  .slot.sel{background:#111;color:#fff}
  .slots{display:flex;gap:8px;flex-wrap:wrap}
  button.cta{all:unset;background:var(--brand);color:#fff;padding:10px 14px;border-radius:10px;cursor:pointer;font-weight:800;text-align:center}
  .toast{position:fixed;bottom:16px;left:50%;transform:translateX(-50%);background:#111;color:#fff;padding:10px 14px;border-radius:999px;display:none}
</style>
</head>
<body>
  <header>
    <div class="nav">
      <div class="logo">🍽️ Dineout</div>
      <input id="q" placeholder="Search restaurants or cuisines (e.g., buffet, biryani, vegan)" />
    </div>
  </header>

  <main class="container">
    <div class="bar">
      <input id="date" type="date" />
      <input id="time" type="time" />
      <select id="party">
        <option>2</option><option>3</option><option>4</option><option>5</option><option>6</option><option>8</option>
      </select>
      <button class="cta" id="find">Find Tables</button>
    </div>

    <div class="grid" id="grid"></div>
  </main>

  <div class="toast" id="toast">Reservation confirmed 🎉</div>

<script>
  const data = [
    { name: "Barbeque Nation", cuisines:["BBQ","Buffet"], area:"Hitech City", rating:4.4, price:"₹₹₹" },
    { name: "AB's Absolute Barbecues", cuisines:["BBQ","Grill"], area:"Gachibowli", rating:4.5, price:"₹₹₹" },
    { name: "Chutneys", cuisines:["South Indian"], area:"Jubilee Hills", rating:4.3, price:"₹₹" },
    { name: "Ohri's Serengeti", cuisines:["North Indian"], area:"Banjara Hills", rating:4.2, price:"₹₹₹" },
    { name: "China Bistro", cuisines:["Chinese"], area:"Film Nagar", rating:4.3, price:"₹₹" },
    { name: "Conçu", cuisines:["Desserts","Cafe"], area:"Jubilee Hills", rating:4.4, price:"₹₹" },
  ];

  const state = { q:"", date:"", time:"", party:"2", slotSel:null };

  const qEl = document.getElementById("q");
  const dateEl = document.getElementById("date");
  const timeEl = document.getElementById("time");
  const partyEl = document.getElementById("party");
  const grid = document.getElementById("grid");
  const toast = document.getElementById("toast");

  function todayStr(offsetDays=0){
    const d = new Date();
    d.setDate(d.getDate()+offsetDays);
    return d.toISOString().slice(0,10);
  }
  dateEl.value = todayStr(0);
  timeEl.value = "19:30";

  function genSlots() {
    const base = ["18:30","19:00","19:30","20:00","20:30","21:00","21:30"];
    return base;
  }

  function draw() {
    let list = [...data];
    if (state.q) {
      const q = state.q.toLowerCase();
      list = list.filter(r =>
        r.name.toLowerCase().includes(q) ||
        r.cuisines.join(",").toLowerCase().includes(q) ||
        r.area.toLowerCase().includes(q)
      );
    }
    grid.innerHTML = "";
    list.forEach(r => {
      const card = document.createElement("div");
      card.className = "card";
      const slots = genSlots();
      card.innerHTML = `
        <div class="thumb">${r.area}</div>
        <div class="row">
          <div>
            <div style="font-weight:800">${r.name}</div>
            <div class="meta">${r.cuisines.join(" • ")}</div>
            <div class="meta">⭐ ${r.rating} · ${r.price}</div>
          </div>
          <div class="meta">📍 ${r.area}</div>
        </div>
        <div class="slots">
          ${slots.map(s=>`<button class="slot" data-s="${s}">${s}</button>`).join("")}
        </div>
        <div class="row">
          <div class="meta">Date: ${dateEl.value} · Time: ${timeEl.value} · Party: ${partyEl.value}</div>
          <button class="cta">Reserve</button>
        </div>
      `;
      const slotBtns = card.querySelectorAll(".slot");
      let selected = null;
      slotBtns.forEach(b=>{
        b.onclick = () => {
          slotBtns.forEach(x=>x.classList.remove("sel"));
          b.classList.add("sel");
          selected = b.dataset.s;
        };
      });
      card.querySelector(".cta").onclick = () => {
        if (!selected) { alert("Please select a time slot"); return; }
        showToast(`Reserved at ${r.name} • ${dateEl.value} ${selected} • ${partyEl.value} people`);
      };
      grid.appendChild(card);
    });
  }

  function showToast(msg) {
    toast.textContent = msg;
    toast.style.display = "block";
    setTimeout(()=> toast.style.display="none", 2500);
  }

  document.getElementById("find").onclick = draw;
  qEl.addEventListener("input", e=> { state.q = e.target.value.trim(); draw(); });
  partyEl.onchange = () => draw();
  timeEl.onchange = () => draw();
  dateEl.onchange = () => draw();

  draw();
</script>
</body>
</html>
EOF'

