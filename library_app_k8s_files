---
# 13. Frontend Deployment
apiVersion: apps/v1
kind: Deployment
metadata:
  name: lib-app
  namespace: srinu
spec:
  replicas: 2
  selector:
    matchLabels:
      app: lib-app
  template:
    metadata:
      labels:
        app: lib-app
    spec:
      containers:
        - name: lib-app
          image: srinuas/mylib:fe
          ports:
            - containerPort: 5000
          envFrom:
            - configMapRef:
                name: app-cm
            - secretRef:
                name: app-sc
          resources:
            requests:
              cpu: "100m"
              memory: "64Mi"
            limits:
              cpu: "200m"
              memory: "128Mi"
          livenessProbe:
            httpGet:
              path: /
              port: 5000
            initialDelaySeconds: 30
            periodSeconds: 10

---
# 14. Frontend Service
apiVersion: v1
kind: Service
metadata:
  name: lib
  namespace: srinu
spec:
  selector:
    app: lib-app
  ports:
    - protocol: TCP
      port: 80
      targetPort: 5000

---
# 15. Ingress
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: lib-ing
  namespace: srinu
  annotations:
    nginx.ingress.kubernetes.io/rewrite-target: /
spec:
  ingressClassName: nginx
  rules:
  - http:
      paths:
      - path: /
        pathType: Prefix
        backend:
          service:
            name: lib
            port:
              number: 80

---
# 16. Horizontal Pod Autoscaler
apiVersion: autoscaling/v2
kind: HorizontalPodAutoscaler
metadata:
  name: lib-app-hpa
  namespace: srinu
spec: 
  scaleTargetRef:
    apiVersion: apps/v1
    kind: Deployment
    name: lib-app
  minReplicas: 2
  maxReplicas: 5
  metrics:
  - type: Resource
    resource:
      name: cpu
      target:
        type: Utilization
        averageUtilization: 60

---
# 17. Network Policy
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: lib-app-network-policy
  namespace: srinu
spec:
  podSelector:
    matchLabels:
      app: lib-app
  policyTypes:
  - Ingress
  - Egress
  ingress:
  - from:
    # Allow ingress-nginx controller pods
    - namespaceSelector:
        matchLabels:
          kubernetes.io/metadata.name: ingress-nginx
      podSelector:
        matchLabels:
          app.kubernetes.io/component: controller
    ports:
    - protocol: TCP
      port: 80

  egress:
  # Allow DB access
  - to:
    - podSelector:
        matchLabels:
          app: lib-db
    ports:
    - protocol: TCP
      port: 3306

  # Allow DNS (VERY IMPORTANT)
  - to:
    - namespaceSelector:
        matchLabels:
          kubernetes.io/metadata.name: kube-system
    ports:
    - protocol: UDP
      port: 53

---
# 18. Pod Disruption Budget
apiVersion: policy/v1
kind: PodDisruptionBudget
metadata:
  name: lib-app-pdb
  namespace: srinu
spec:
  minAvailable: 2
  selector:
    matchLabels:
      app: lib-app

