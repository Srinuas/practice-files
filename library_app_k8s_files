# 1. Namespace
apiVersion: v1
kind: Namespace
metadata:
  name: srinu

---
# 2. ConfigMap
apiVersion: v1
kind: ConfigMap
metadata:
  name: app-cm
  namespace: srinu
data:
  DB_HOST: "db"
  DB_PORT: "3306"
  app_version: "1.0"

---
# 3. Secret
apiVersion: v1
kind: Secret
metadata:
  name: app-sc
  namespace: srinu
type: Opaque
data:
  # Base64 encoded values
  MYSQL_ROOT_PASSWORD: cm9vdA== 
  DB_USER: cm9vdA==
  DB_PASSWORD: cm9vdA==
  DB_NAME: ZGlnaXRhbF9saWJyYXJ5

---
# 4. Resource Quota
apiVersion: v1
kind: ResourceQuota
metadata:
  name: app-svc-rq
  namespace: srinu
spec:
  hard:
    pods: "10"
    requests.cpu: "2"
    requests.memory: 4Gi
    limits.cpu: "2"
    limits.memory: 4Gi

---
# 5. DB StatefulSet
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: lib-db
  namespace: srinu
spec:
  serviceName: "db"
  replicas: 1
  selector:
    matchLabels:
      app: lib-db
  template:
    metadata:
      labels:
        app: lib-db
    spec:
      containers:
        - name: lib-db
          image: srinuas/mylib:db
          ports:
            - containerPort: 3306
              name: mysql
          env:
            - name: MYSQL_ROOT_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: app-sc
                  key: DB_PASSWORD
          # ✅ resources MUST be here (under the container)
          resources:
            requests:
              cpu: "200m"
              memory: "128Mi"
            limits:
              cpu: "400m"
              memory: "256Mi"
          volumeMounts:
            - name: db-pvc
              # ⚠️ సాధారణ MySQL data-dir: /var/lib/mysql  (lowercase)
              # నీ ఇమేజ్ నిజంగా /var/lib/MySQL అయితే అదే ఉంచు. లేదంటే క్రిందలాగే ఉంచు:
              mountPath: /var/lib/mysql

  volumeClaimTemplates:
    - metadata:
        name: db-pvc
      spec:
        accessModes: [ "ReadWriteOnce" ]
        resources:
          requests:
            storage: 1Gi

---
# 6. DB Service
apiVersion: v1
kind: Service
metadata:
  name: db
  namespace: srinu
spec:
  clusterIP: None
  selector:
    app: lib-db
  ports:
    - port: 3306
      targetPort: 3306


---
# 7. Auth Deployment
apiVersion: apps/v1
kind: Deployment
metadata:
  name: lib-auth
  namespace: srinu
spec:
  replicas: 1
  selector:
    matchLabels:
      app: lib-auth
  template:
    metadata:
      labels:
        app: lib-auth
    spec:
      containers:
        - name: lib-auth
          image: srinuas/mylib:au
          ports:
            - containerPort: 5001
          envFrom:
            - configMapRef:
                name: app-cm
            - secretRef:
                name: app-sc
          resources:
            requests:
              cpu: "100m"
              memory: "64Mi"
            limits:
              cpu: "200m"
              memory: "128Mi"
          livenessProbe:
            httpGet:
              path: /
              port: 5001
            initialDelaySeconds: 30
            periodSeconds: 10

---
# 8. Auth Service
apiVersion: v1
kind: Service
metadata:
  name: auth
  namespace: srinu
spec:
  selector:
    app: lib-auth
  ports:
    - port: 5001
      targetPort: 5001

---
